[Unit]
Description=MacNix Fingerprint Bridge
After=macnix-vm.service
Requires=macnix-vm.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/macnix/scripts/macnix-fingerprint-bridge.py daemon
Restart=on-failure
RestartSec=5
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=graphical.target
